# ---------------------------------------------------------------
# Prompt Protect — Environment Variables
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------

# Required: Your OpenAI API key
OPENAI_API_KEY=

# Optional: Override the secret key base (a default is provided for local Docker use)
# Generate a new one for production with: bundle exec rails secret
# SECRET_KEY_BASE=

# Optional: Override the LLM provider base URL (default: https://api.openai.com)
# Use this to point at a local proxy, Azure OpenAI, or any OpenAI-compatible API.
OPENAI_API_BASE_URL=https://api.openai.com

# Optional: Allowed CORS origins (default: * — restrict in production)
CORS_ORIGINS=*

# Optional: Policy per risk level (default: allow / sanitize / block)
# Accepted values: allow | sanitize | block
PROMPT_PROTECT_POLICY_LOW=allow
PROMPT_PROTECT_POLICY_MEDIUM=sanitize
PROMPT_PROTECT_POLICY_HIGH=block

# Optional: LLM provider adapter (default: openai)
# Accepted values: openai
# anthropic and cohere adapters are not yet implemented
# PROMPT_PROTECT_PROVIDER=openai

# Optional: spaCy NER sidecar (default: enabled)
# Set to false to use regex-only detection (no Docker sidecar needed)
# SPACY_ENABLED=true
# SPACY_SERVICE_URL=http://spacy:5001
# SPACY_MODEL=en_core_web_sm
